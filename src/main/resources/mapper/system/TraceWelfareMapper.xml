<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.trace.mapper.TraceWelfareMapper">
    
    <resultMap type="TraceWelfare" id="TraceWelfareResult">
        <result property="id"    column="id"    />
        <result property="status"    column="status"    />
        <result property="name"    column="name"    />
        <result property="num"    column="num"    />
        <result property="remark"    column="remark"    />
        <result property="ext1"    column="ext1"    />
        <result property="ext2"    column="ext2"    />
    </resultMap>

    <sql id="selectTraceWelfareVo">
        select id, status, name, num, remark, ext1, ext2 from trace_welfare
    </sql>

    <select id="selectTraceWelfareList" parameterType="TraceWelfare" resultMap="TraceWelfareResult">
        <include refid="selectTraceWelfareVo"/>
        <where>  
            <if test="status != null "> and status = #{status}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="num != null "> and num = #{num}</if>
            <if test="ext1 != null  and ext1 != ''"> and ext1 = #{ext1}</if>
            <if test="ext2 != null  and ext2 != ''"> and ext2 = #{ext2}</if>
        </where>
    </select>
    
    <select id="selectTraceWelfareById" parameterType="Long" resultMap="TraceWelfareResult">
        <include refid="selectTraceWelfareVo"/>
        where id = #{id}
    </select>

    <insert id="insertTraceWelfare" parameterType="TraceWelfare" useGeneratedKeys="true" keyProperty="id">
        insert into trace_welfare
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="status != null">status,</if>
            <if test="name != null">name,</if>
            <if test="num != null">num,</if>
            <if test="remark != null">remark,</if>
            <if test="ext1 != null">ext1,</if>
            <if test="ext2 != null">ext2,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="status != null">#{status},</if>
            <if test="name != null">#{name},</if>
            <if test="num != null">#{num},</if>
            <if test="remark != null">#{remark},</if>
            <if test="ext1 != null">#{ext1},</if>
            <if test="ext2 != null">#{ext2},</if>
         </trim>
    </insert>

    <update id="updateTraceWelfare" parameterType="TraceWelfare">
        update trace_welfare
        <trim prefix="SET" suffixOverrides=",">
            <if test="status != null">status = #{status},</if>
            <if test="name != null">name = #{name},</if>
            <if test="num != null">num = #{num},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="ext1 != null">ext1 = #{ext1},</if>
            <if test="ext2 != null">ext2 = #{ext2},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTraceWelfareById" parameterType="Long">
        delete from trace_welfare where id = #{id}
    </delete>

    <delete id="deleteTraceWelfareByIds" parameterType="String">
        delete from trace_welfare where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>