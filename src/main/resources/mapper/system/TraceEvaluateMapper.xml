<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.trace.mapper.TraceEvaluateMapper">
    
    <resultMap type="TraceEvaluate" id="TraceEvaluateResult">
        <result property="id"    column="id"    />
        <result property="nickName"    column="nick_name"    />
        <result property="content"    column="content"    />
        <result property="blockHash"    column="block_hash"    />
        <result property="blockNumber"    column="block_number"    />
        <result property="ext1"    column="ext1"    />
        <result property="ext2"    column="ext2"    />
    </resultMap>

    <sql id="selectTraceEvaluateVo">
        select id, nick_name, content, block_hash, block_number, ext1, ext2 from trace_evaluate
    </sql>

    <select id="selectTraceEvaluateList" parameterType="TraceEvaluate" resultMap="TraceEvaluateResult">
        <include refid="selectTraceEvaluateVo"/>
        <where>  
            <if test="nickName != null  and nickName != ''"> and nick_name like concat('%', #{nickName}, '%')</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="blockHash != null  and blockHash != ''"> and block_hash = #{blockHash}</if>
            <if test="blockNumber != null "> and block_number = #{blockNumber}</if>
            <if test="ext1 != null  and ext1 != ''"> and ext1 = #{ext1}</if>
            <if test="ext2 != null  and ext2 != ''"> and ext2 = #{ext2}</if>
        </where>
    </select>
    
    <select id="selectTraceEvaluateById" parameterType="Long" resultMap="TraceEvaluateResult">
        <include refid="selectTraceEvaluateVo"/>
        where id = #{id}
    </select>

    <insert id="insertTraceEvaluate" parameterType="TraceEvaluate">
        insert into trace_evaluate
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="nickName != null">nick_name,</if>
            <if test="content != null">content,</if>
            <if test="blockHash != null">block_hash,</if>
            <if test="blockNumber != null">block_number,</if>
            <if test="ext1 != null">ext1,</if>
            <if test="ext2 != null">ext2,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="nickName != null">#{nickName},</if>
            <if test="content != null">#{content},</if>
            <if test="blockHash != null">#{blockHash},</if>
            <if test="blockNumber != null">#{blockNumber},</if>
            <if test="ext1 != null">#{ext1},</if>
            <if test="ext2 != null">#{ext2},</if>
         </trim>
    </insert>

    <update id="updateTraceEvaluate" parameterType="TraceEvaluate">
        update trace_evaluate
        <trim prefix="SET" suffixOverrides=",">
            <if test="nickName != null">nick_name = #{nickName},</if>
            <if test="content != null">content = #{content},</if>
            <if test="blockHash != null">block_hash = #{blockHash},</if>
            <if test="blockNumber != null">block_number = #{blockNumber},</if>
            <if test="ext1 != null">ext1 = #{ext1},</if>
            <if test="ext2 != null">ext2 = #{ext2},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTraceEvaluateById" parameterType="Long">
        delete from trace_evaluate where id = #{id}
    </delete>

    <delete id="deleteTraceEvaluateByIds" parameterType="String">
        delete from trace_evaluate where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>